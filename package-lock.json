version: '3.8'

services:
  db:
    image: postgres:14-alpine
    environment:
      POSTGRES_DB: tko_control
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: secretpassword
    volumes:
      - postgres_data:/var/lib/postgresql/data

  backend:
    build: 
      context: ./backend
    environment:
      DATABASE_URL: postgresql://admin:secretpassword@db:5432/tko_control
      GLONASSSOFT_LOGIN: ${GLONASSSOFT_LOGIN}
      GLONASSSOFT_PASSWORD: ${GLONASSSOFT_PASSWORD}
    ports:
      - "8000:8000"
    depends_on:
      - db

  frontend:
    build: .
    ports:
      - "80:80"
    depends_on:
      - backend

volumes:
  postgres_data:
