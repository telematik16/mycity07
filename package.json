import * as XLSX from 'xlsx';
import type { ColumnMapping, ComparisonResult, PlanRow, FactRow } from '../types';

export function parseFile(file: File): Promise<string[]> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const data = e.target?.result;
        const workbook = XLSX.read(data, { type: 'array' });
        const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
        const jsonData = XLSX.utils.sheet_to_json<Record<string, unknown>>(firstSheet, { defval: '' });
        if (jsonData.length === 0) {
          resolve([]);
          return;
        }
        const headers = Object.keys(jsonData[0]);
        resolve(headers);
      } catch (err) {
        reject(err);
      }
    };
    reader.onerror = reject;
    reader.readAsArrayBuffer(file);
  });
}

export function parseFileData(file: File): Promise<Record<string, string>[]> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const data = e.target?.result;
        const workbook = XLSX.read(data, { type: 'array' });
        const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
        const jsonData = XLSX.utils.sheet_to_json<Record<string, unknown>>(firstSheet, { defval: '' });
        const stringData: Record<string, string>[] = jsonData.map((row) => {
          const newRow: Record<string, string> = {};
          for (const [key, value] of Object.entries(row)) {
            newRow[key] = String(value);
          }
          return newRow;
        });
        resolve(stringData);
      } catch (err) {
        reject(err);
      }
    };
    reader.onerror = reject;
    reader.readAsArrayBuffer(file);
  });
}

function preprocessPlate(value: string): string {
  return value.trim().toUpperCase();
}

function preprocessAddress(value: string): string {
  return value.trim();
}

export function compareData(
  planData: Record<string, string>[],
  factData: Record<string, string>[],
  mapping: ColumnMapping
): ComparisonResult {
  // Build a set of fact keys: [PLATE + ADDRESS]
  const factKeys = new Set<string>();
  for (const row of factData) {
    const plate = preprocessPlate(row[mapping.factPlateCol] || '');
    const address = preprocessAddress(row[mapping.factAddressCol] || '');
    if (plate && address) {
      factKeys.add(`${plate}|||${address}`);
    }
  }

  // Build a set of plan keys: [PLATE + ADDRESS]
  const planKeys = new Set<string>();
  for (const row of planData) {
    const plate = preprocessPlate(row[mapping.planPlateCol] || '');
    const address = preprocessAddress(row[mapping.planAddressCol] || '');
    if (plate && address) {
      planKeys.add(`${plate}|||${address}`);
    }
  }

  // Process plan rows - add status
  const planWithStatus: PlanRow[] = planData.map((row) => {
    const plate = preprocessPlate(row[mapping.planPlateCol] || '');
    const address = preprocessAddress(row[mapping.planAddressCol] || '');
    const key = `${plate}|||${address}`;
    const visited = factKeys.has(key);
    return {
      ...row,
      _plate: plate,
      _address: address,
      _status: visited ? 'Посещен' : 'Не посещен',
    };
  });

  // Process fact rows - find out-of-plan
  const factOutOfPlan: FactRow[] = [];
  const processedFactKeys = new Set<string>();

  for (const row of factData) {
    const plate = preprocessPlate(row[mapping.factPlateCol] || '');
    const address = preprocessAddress(row[mapping.factAddressCol] || '');
    const key = `${plate}|||${address}`;
    
    if (processedFactKeys.has(key)) continue;
    processedFactKeys.add(key);

    const inPlan = planKeys.has(key);
    if (!inPlan) {
      factOutOfPlan.push({
        ...row,
        _plate: plate,
        _address: address,
        _status: 'Вне плана',
      });
    }
  }

  const totalPlan = planWithStatus.length;
  const visited = planWithStatus.filter((r) => r._status === 'Посещен').length;
  const notVisited = totalPlan - visited;
  const outOfPlan = factOutOfPlan.length;

  return {
    planWithStatus,
    factOutOfPlan,
    metrics: { totalPlan, visited, notVisited, outOfPlan },
  };
}

export function exportToExcel(result: ComparisonResult): void {
  const wb = XLSX.utils.book_new();

  // Sheet 1: Анализ Плана
  const planExport = result.planWithStatus.map((row) => {
    // Формируем строку так, чтобы госномер и адрес были первыми колонками
    const newRow: Record<string, string> = {
      'Гос. номер': String(row._plate),
      'Адрес': String(row._address),
      'Статус': row._status
    };
    
    // Добавляем остальные оригинальные колонки, если их еще нет
    for (const [key, value] of Object.entries(row)) {
      if (!key.startsWith('_') && key !== 'Статус') {
        newRow[key] = String(value);
      }
    }
    return newRow;
  });
  const ws1 = XLSX.utils.json_to_sheet(planExport);
  XLSX.utils.book_append_sheet(wb, ws1, 'Анализ Плана');

  // Sheet 2: Внеплановые посещения
  const factExport = result.factOutOfPlan.map((row) => {
    const newRow: Record<string, string> = {
      'Гос. номер': String(row._plate),
      'Адрес': String(row._address),
      'Статус': row._status
    };
    
    for (const [key, value] of Object.entries(row)) {
      if (!key.startsWith('_') && key !== 'Статус') {
        newRow[key] = String(value);
      }
    }
    return newRow;
  });
  const ws2 = XLSX.utils.json_to_sheet(factExport);
  XLSX.utils.book_append_sheet(wb, ws2, 'Внеплановые посещения');

  XLSX.writeFile(wb, 'Отчет_Сверка_ТКО.xlsx');
}
